# Copy to `.env.local` and set values from your Supabase project dashboard.
# Do not commit `.env.local` or paste real keys into the repo.
#
# Vercel: Project → Settings → General → Root Directory = `frontend`
#         (저장소 루트가 아니라 이 폴더를 앱 루트로 지정해야 빌드가 됩니다.)
#         Project → Settings → Environment Variables 에도 아래 키를 Production/Preview에 넣으세요.
#         (빌드는 env 없이도 통과하지만, 배포 후 실제 로그인·API는 이 값이 있어야 동작합니다.)
#
# Plan: dashboard project display name `vibe-tutorial` (identify the app there).
# If the org is at the free project limit, pause/delete another project or reuse an existing ref.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 배포 URL이 Vercel 기본 도메인이 아니면(커스텀 도메인 등) 반드시 설정.
# 예: https://your-app.vercel.app 또는 https://yourdomain.com
# NEXT_PUBLIC_SITE_URL=

# Supabase: Authentication → URL Configuration
#   Site URL = 배포 사이트 루트 (위와 동일 권장)
#   Redirect URLs 에 다음을 포함:
#   https://<배포도메인>/auth/callback
#   Preview용으로 https://*.vercel.app/auth/callback 도 추가 가능

# Optional: default team UUID so `?teamId=` can be omitted on `/` and `/history` when testing.
# NEXT_PUBLIC_DEFAULT_TEAM_ID=
